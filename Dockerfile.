# Stage 1: build — Drogon already compiled in base image
FROM drogonframework/drogon:latest AS builder

ENV DEBIAN_FRONTEND=noninteractive

# Extra deps not in drogon base: rdkafka, libpq-dev (ensure PG support), bcrypt, jwt-cpp
RUN apt-get update && apt-get install -y \
    libpq-dev \
    librdkafka-dev \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/hilch/Bcrypt.cpp.git /tmp/bcrypt && \
    cd /tmp/bcrypt && mkdir build && cd build && \
    cmake .. && make && \
    cp libbcrypt.a /usr/local/lib/ && \
    cp ../include/bcrypt.h /usr/local/include/ && \
    ldconfig && rm -rf /tmp/bcrypt

RUN git clone https://github.com/Thalhammer/jwt-cpp.git /tmp/jwt-cpp && \
    cd /tmp/jwt-cpp && git checkout v0.7.0 && \
    cp -r include/jwt-cpp /usr/local/include/ && \
    git clone https://github.com/kazuho/picojson.git /tmp/picojson && \
    mkdir -p /usr/local/include/picojson && \
    cp /tmp/picojson/picojson.h /usr/local/include/picojson/ && \
    rm -rf /tmp/jwt-cpp /tmp/picojson

WORKDIR /build
COPY . .

RUN mkdir -p build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    make -j$(nproc)

# Stage 2: minimal runtime (ubuntu matches drogonframework/drogon builder base)
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    libpq5 \
    libjsoncpp25 \
    libssl3 \
    uuid-runtime \
    libyaml-cpp0.7 \
    librdkafka1 \
    librdkafka++1 \
    libc-ares2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /build/build/project-calendar /app/

EXPOSE 8080
CMD ["./project-calendar"]
